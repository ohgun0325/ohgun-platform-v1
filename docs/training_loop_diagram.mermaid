%% 학습 루프 전체 플로우 다이어그램

graph TB
    Start([시작: koreapost_spem_list.csv]) --> DataPrep[데이터 전처리<br/>95,134개 레코드]
    
    DataPrep --> Split{데이터 분할}
    Split --> Train[학습 데이터<br/>80%]
    Split --> Val[검증 데이터<br/>10%]
    Split --> Test[테스트 데이터<br/>10%]
    
    Train --> SFT[SFT 단계<br/>Supervised Fine-Tuning<br/>Base: EXAONE 3.5 2.4B]
    Val --> SFT
    
    SFT --> SFTEval{SFT 평가<br/>Accuracy > 80%?}
    SFTEval -- Yes --> QLoRA[QLoRA 최적화<br/>4-bit Quantization<br/>LoRA Adapters]
    SFTEval -- No --> SFTFeedback[피드백 수집<br/>데이터 증강]
    SFTFeedback --> SFT
    
    QLoRA --> QLoRAEval{QLoRA 평가<br/>Accuracy > 85%?}
    QLoRAEval -- Yes --> RLHF[RLHF 단계<br/>Reward Model 학습<br/>PPO 최적화]
    QLoRAEval -- No --> QLoRAFeedback[하이퍼파라미터 조정]
    QLoRAFeedback --> QLoRA
    
    RLHF --> RLHFEval{RLHF 평가<br/>Human Feedback<br/>품질 > 4.0?}
    RLHFEval -- Yes --> DPO[DPO 단계<br/>Direct Preference<br/>Optimization]
    RLHFEval -- No --> RLHFFeedback[Preference 데이터 추가]
    RLHFFeedback --> RLHF
    
    DPO --> FinalEval{최종 평가<br/>Accuracy > 95%?}
    Test --> FinalEval
    
    FinalEval -- Yes --> Deploy[모델 배포<br/>Production Ready]
    FinalEval -- No --> Iteration{반복 횟수<br/>< Max?}
    
    Iteration -- Yes --> FeedbackIntegration[피드백 통합<br/>데이터 증강]
    Iteration -- No --> BestModel[최선 모델 선택<br/>조기 종료]
    
    FeedbackIntegration --> SFT
    
    Deploy --> Monitor[모니터링<br/>성능 추적]
    BestModel --> Monitor
    
    Monitor --> ActiveLearning{새로운<br/>스팸 패턴?}
    ActiveLearning -- Yes --> Retrain[재학습<br/>Continual Learning]
    ActiveLearning -- No --> Monitor
    
    Retrain --> SFT
    
    style Start fill:#e1f5ff
    style DataPrep fill:#fff4e1
    style SFT fill:#ffe1e1
    style QLoRA fill:#ffe1e1
    style RLHF fill:#ffe1e1
    style DPO fill:#ffe1e1
    style Deploy fill:#e1ffe1
    style Monitor fill:#f0e1ff
